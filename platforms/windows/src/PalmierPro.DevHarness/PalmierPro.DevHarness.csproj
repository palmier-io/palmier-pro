<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>PalmierPro.DevHarness</RootNamespace>
    <AssemblyName>PalmierPro.DevHarness</AssemblyName>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Platforms>x64</Platforms>
    <!-- Hand-written Main in Program.cs so the headless dump-frame flag can run
         without Application.Start, before falling through to the normal WinUI app. -->
    <DefineConstants>$(DefineConstants);DISABLE_XAML_GENERATED_MAIN</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.*" />
    <PackageReference Include="Serilog" Version="4.*" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.*" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.*" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="9.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PalmierPro.Core\PalmierPro.Core.csproj" />
    <ProjectReference Include="..\PalmierPro.Services\PalmierPro.Services.csproj" />
    <ProjectReference Include="..\PalmierPro.Rendering\PalmierPro.Rendering.csproj" />
  </ItemGroup>

  <!-- Same `dotnet publish` gap as PalmierPro.App.csproj (see its comment) — kept here too
       in case DevHarness is ever published standalone. -->
  <Target Name="IncludeWinUIXamlOutputInPublish" AfterTargets="Publish">
    <ItemGroup>
      <_WinUIPublishGap Include="$(OutDir)**\*.xbf" Condition="Exists('$(OutDir)')" />
      <_WinUIPublishGap Include="$(OutDir)$(TargetName).pri" Condition="Exists('$(OutDir)$(TargetName).pri')" />
    </ItemGroup>
    <Copy SourceFiles="@(_WinUIPublishGap)"
          DestinationFiles="@(_WinUIPublishGap->'$(PublishDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
