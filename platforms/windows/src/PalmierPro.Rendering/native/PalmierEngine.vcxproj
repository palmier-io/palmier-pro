<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Deliberately not a member of PalmierPro.sln: the dotnet CLI cannot build vcxproj
    (MSB4278). Build via `msbuild PalmierEngine.vcxproj -p:Configuration=... -p:Platform=x64`,
    which scripts/dev.ps1 and CI both do explicitly. See docs/README.md.
  -->
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <ProjectGuid>{83FBD16F-DFB8-44B3-A0B9-B2559A30F172}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>PalmierEngine</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Label="Configuration">
    <ConfigurationType>DynamicLibrary</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
    <UseDebugLibraries Condition="'$(Configuration)'=='Debug'">true</UseDebugLibraries>
    <UseDebugLibraries Condition="'$(Configuration)'=='Release'">false</UseDebugLibraries>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <ImportGroup Label="ExtensionSettings" />

  <ImportGroup Label="Shared" />

  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <PropertyGroup>
    <!-- Not built as part of PalmierPro.sln, so $(SolutionDir) is undefined here; anchor on
         $(MSBuildThisFileDirectory) instead. Resolves to platforms/windows/artifacts/. -->
    <TargetName>PalmierEngine</TargetName>
    <OutDir>$(MSBuildThisFileDirectory)..\..\..\artifacts\native\$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(MSBuildThisFileDirectory)..\..\..\artifacts\native\obj\$(Platform)\$(Configuration)\PalmierEngine\</IntDir>
    <!-- Restored by scripts/ci-restore-ffmpeg.ps1 (see ../../../ffmpeg.lock.json); not checked in. -->
    <FFmpegDir>$(MSBuildThisFileDirectory)..\..\..\third_party\ffmpeg\</FFmpegDir>
  </PropertyGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Debug'">
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>PALMIERENGINE_EXPORTS;_DEBUG;_WINDOWS;_USRDLL;NOMINMAX;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <SDLCheck>true</SDLCheck>
      <RuntimeLibrary>MultiThreadedDebugDLL</RuntimeLibrary>
      <AdditionalIncludeDirectories>$(FFmpegDir)include;third_party\simdjson;third_party\signalsmith-stretch;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalLibraryDirectories>$(FFmpegDir)lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>avformat.lib;avcodec.lib;avutil.lib;swscale.lib;swresample.lib;d3d11.lib;dxgi.lib;d3dcompiler.lib;windowscodecs.lib;dwrite.lib;d2d1.lib;xaudio2.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)'=='Release'">
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>PALMIERENGINE_EXPORTS;NDEBUG;_WINDOWS;_USRDLL;NOMINMAX;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <SDLCheck>true</SDLCheck>
      <RuntimeLibrary>MultiThreadedDLL</RuntimeLibrary>
      <AdditionalIncludeDirectories>$(FFmpegDir)include;third_party\simdjson;third_party\signalsmith-stretch;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalLibraryDirectories>$(FFmpegDir)lib;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>avformat.lib;avcodec.lib;avutil.lib;swscale.lib;swresample.lib;d3d11.lib;dxgi.lib;d3dcompiler.lib;windowscodecs.lib;dwrite.lib;d2d1.lib;xaudio2.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="PalmierEngine.cpp" />
    <ClCompile Include="EngineSession.cpp" />
    <ClCompile Include="MediaSource.cpp" />
    <ClCompile Include="D3D11Presenter.cpp" />
    <ClCompile Include="WicPngWriter.cpp" />
    <ClCompile Include="WicImageReader.cpp" />
    <ClCompile Include="TimelineSnapshotParser.cpp" />
    <ClCompile Include="Compositor.cpp" />
    <ClCompile Include="MediaCache.cpp" />
    <ClCompile Include="TimelineRegistry.cpp" />
    <ClCompile Include="TimelineSession.cpp" />
    <ClCompile Include="PlaybackClock.cpp" />
    <ClCompile Include="EffectRegistry.cpp" />
    <ClCompile Include="CubeLutParser.cpp" />
    <ClCompile Include="CurveMath.cpp" />
    <ClCompile Include="GpuCompositor.cpp" />
    <ClCompile Include="FontRegistry.cpp" />
    <ClCompile Include="TextRenderer.cpp" />
    <ClCompile Include="TextAnimator.cpp" />
    <ClCompile Include="AudioEngine.cpp" />
    <ClCompile Include="AudioMixer.cpp" />
    <ClCompile Include="ScrubAudio.cpp" />
    <ClCompile Include="RetimeStretcher.cpp" />
    <!-- Vendored amalgamated single-source build (native/third_party/simdjson/) — reduced
         warning level, this translation unit is upstream code, not ours to fix warnings in. -->
    <ClCompile Include="third_party\simdjson\simdjson.cpp">
      <WarningLevel>Level1</WarningLevel>
    </ClCompile>
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="include\palmier_engine.h" />
    <ClInclude Include="EngineSession.h" />
    <ClInclude Include="MediaSource.h" />
    <ClInclude Include="D3D11Presenter.h" />
    <ClInclude Include="WinUISwapChainInterop.h" />
    <ClInclude Include="WicPngWriter.h" />
    <ClInclude Include="WicImageReader.h" />
    <ClInclude Include="Half.h" />
    <ClInclude Include="Affine2D.h" />
    <ClInclude Include="TimelineSnapshot.h" />
    <ClInclude Include="TimelineSnapshotParser.h" />
    <ClInclude Include="Compositor.h" />
    <ClInclude Include="MediaCache.h" />
    <ClInclude Include="TimelineRegistry.h" />
    <ClInclude Include="TimelineSession.h" />
    <ClInclude Include="PlaybackClock.h" />
    <ClInclude Include="third_party\simdjson\simdjson.h" />
    <ClInclude Include="Keyframe.h" />
    <ClInclude Include="ClipGeometry.h" />
    <ClInclude Include="ColorWheels.h" />
    <ClInclude Include="CurveMath.h" />
    <ClInclude Include="CubeLutParser.h" />
    <ClInclude Include="EffectRegistry.h" />
    <ClInclude Include="GpuCompositor.h" />
    <ClInclude Include="FontRegistry.h" />
    <ClInclude Include="TextRenderer.h" />
    <ClInclude Include="TextAnimator.h" />
    <ClInclude Include="AudioEngine.h" />
    <ClInclude Include="AudioMixer.h" />
    <ClInclude Include="ScrubAudio.h" />
    <ClInclude Include="RetimeStretcher.h" />
    <ClInclude Include="third_party\signalsmith-stretch\signalsmith-stretch.h" />
  </ItemGroup>

  <ItemGroup>
    <!-- Not compiled — runtime D3DCompile sources, deployed next to PalmierEngine.dll via
         PalmierPro.Rendering.csproj's Content items (see GpuCompositor.cpp's
         ResolveShadersDir). Listed here only so they show up in the VS solution explorer. -->
    <None Include="shaders\Common.hlsl" />
    <None Include="shaders\Fullscreen.hlsl" />
    <None Include="shaders\Ingest.hlsl" />
    <None Include="shaders\Levels.hlsl" />
    <None Include="shaders\HighlightsShadows.hlsl" />
    <None Include="shaders\Wheels.hlsl" />
    <None Include="shaders\ChromaKey.hlsl" />
    <None Include="shaders\Vignette.hlsl" />
    <None Include="shaders\Grain.hlsl" />
    <None Include="shaders\GradeCurves.hlsl" />
    <None Include="shaders\HueCurves.hlsl" />
    <None Include="shaders\LUTTetra.hlsl" />
    <None Include="shaders\Blur.hlsl" />
    <None Include="shaders\GlowBright.hlsl" />
    <None Include="shaders\GlowComposite.hlsl" />
    <None Include="shaders\Clarity.hlsl" />
    <None Include="shaders\Composite.hlsl" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>
