<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>PalmierPro.Rendering</RootNamespace>
    <AssemblyName>PalmierPro.Rendering</AssemblyName>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\PalmierPro.Core\PalmierPro.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Stages PalmierEngine.dll (built by native/PalmierEngine.vcxproj into artifacts/native/)
         next to the managed output so P/Invoke can find it. Condition avoids a build break
         when the native project hasn't been built yet. -->
    <Content Include="..\..\artifacts\native\x64\$(Configuration)\PalmierEngine.dll"
             Condition="Exists('..\..\artifacts\native\x64\$(Configuration)\PalmierEngine.dll')">
      <Link>PalmierEngine.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>

    <!-- FFmpeg runtime DLLs PalmierEngine.dll links against (restored by
         scripts/ci-restore-ffmpeg.ps1 into third_party/ffmpeg/bin, gitignored). Only the
         five libraries actually linked (see native/PalmierEngine.vcxproj) — not
         avdevice/avfilter/ffmpeg.exe, which nothing in the engine calls into. -->
    <FFmpegRuntimeDll Include="..\..\third_party\ffmpeg\bin\avformat-*.dll" />
    <FFmpegRuntimeDll Include="..\..\third_party\ffmpeg\bin\avcodec-*.dll" />
    <FFmpegRuntimeDll Include="..\..\third_party\ffmpeg\bin\avutil-*.dll" />
    <FFmpegRuntimeDll Include="..\..\third_party\ffmpeg\bin\swscale-*.dll" />
    <FFmpegRuntimeDll Include="..\..\third_party\ffmpeg\bin\swresample-*.dll" />
    <Content Include="@(FFmpegRuntimeDll)">
      <Link>%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>

    <!-- E3: HLSL kernel/composite sources, D3DCompile'd at runtime by GpuCompositor.cpp, which
         resolves them next to PalmierEngine.dll's own module path (see its ResolveShadersDir) —
         so they must land in a "shaders" subfolder alongside the DLL, same staging mechanism as
         PalmierEngine.dll/the FFmpeg DLLs above. -->
    <Content Include="native\shaders\*.hlsl">
      <Link>shaders\%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>

    <!-- E4: the 13 bundled caption/title font families, referenced directly from the Mac
         app's own Resources/Fonts (never duplicated into platforms/windows — one set of
         font binaries for both platforms) and staged into a "fonts" subfolder next to
         PalmierEngine.dll, same mechanism as the shaders above. FontRegistry.cpp's
         ResolveFontsDir resolves that folder the same way GpuCompositor's ResolveShadersDir
         does — anchored on this DLL's own module path, not the host process's. -->
    <BundledFontFile Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\**\*.ttf" />
    <BundledFontFile Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\**\*.otf" />
    <Content Include="@(BundledFontFile)">
      <Link>fonts\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
