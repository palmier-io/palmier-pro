<Window
    x:Class="PalmierPro.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Grid (a Panel) has no FontFamily of its own — WinUI's font-property inheritance flows down
         from a Control ancestor, so the default lives on this wrapping ContentControl. -->
    <ContentControl
        FontFamily="{StaticResource AppFontFamily}"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        IsTabStop="False">
        <Grid Background="{StaticResource AppBackgroundBaseBrush}" />
    </ContentControl>
</Window>
