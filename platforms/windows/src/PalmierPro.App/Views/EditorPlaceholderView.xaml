<UserControl
    x:Class="PalmierPro.App.Views.EditorPlaceholderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mediaPanel="using:PalmierPro.App.Views.MediaPanel"
    mc:Ignorable="d">

    <!-- Media panel is real (Stage B); preview/inspector/timeline remain themed skeletons until
         their own stages (C/D). -->
    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBaseBrush}"
          RowSpacing="{StaticResource AppSpacingSm}">
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="TopRow" Grid.Row="0" ColumnSpacing="{StaticResource AppSpacingSm}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="MediaPanel" Grid.Column="0">
                <mediaPanel:MediaPanelView x:Name="MediaPanelHost"/>
            </Border>
            <Border x:Name="PreviewPanel" Grid.Column="1" Background="{StaticResource AppBackgroundPreviewCanvasBrush}"/>
            <Border x:Name="InspectorPanel" Grid.Column="2" Background="{StaticResource AppBackgroundRaisedBrush}"/>
        </Grid>

        <Border x:Name="TimelinePanel" Grid.Row="1" Background="{StaticResource AppBackgroundRaisedBrush}"/>
    </Grid>
</UserControl>
