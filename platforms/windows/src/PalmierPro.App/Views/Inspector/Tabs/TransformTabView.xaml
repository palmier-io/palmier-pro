<UserControl
    x:Class="PalmierPro.App.Views.Inspector.Tabs.TransformTabView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Video tab content (M5, Stage E) — ports InspectorView.swift's `videoTabContent`/
         `transformSection`/`speedSection`: position/scale/rotation/opacity (each with a keyframe
         stamp/nav diamond), crop aspect preset, flip, blend mode, Reset Transform, and the Speed
         (Playback) section. The Mac's inline keyframes-panel split view is NOT ported — Windows
         exposes Keyframes as its own top-level tab (InspectorTab.Keyframes) instead of a toggle
         within this one; only the per-row stamp/nav controls carry over. Rows are built in
         code-behind off TransformViewModel, matching InspectorView.xaml.cs/TimelineTabBarView's
         own convention for selection/frame-driven content that doesn't fit a static template. -->
    <ScrollViewer x:Name="RootScroll">
        <StackPanel x:Name="RootStack" Spacing="{StaticResource AppSpacingLg}"/>
    </ScrollViewer>
</UserControl>
