<UserControl
    x:Class="PalmierPro.App.Views.Inspector.Tabs.ColorCurveEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:inspector="using:PalmierPro.App.Views.Inspector"
    mc:Ignorable="d">

    <!-- Port of CurveEditorView.swift (Inspector/Components/Adjust) — the master/R/G/B grade-curve
         editor behind the "Curves" section (color.curves). ScopesHistogramView draws the read-only
         scope backdrop (grid/border/diagonal reference + luma/RGB histogram, docs/color-scopes-v1.md);
         this view is the transparent interactive overlay on top of it — the layering split that
         file's own doc comment calls out. -->
    <StackPanel x:Name="Root" Spacing="{StaticResource AppSpacingSm}">
        <StackPanel x:Name="ChannelRow" Orientation="Horizontal" Spacing="{StaticResource AppSpacingSm}"/>

        <Grid x:Name="EditorGrid" Height="{StaticResource AppCurveEditorHeight}">
            <inspector:ScopesHistogramView x:Name="Backdrop"/>
            <canvas:CanvasControl x:Name="Canvas"
                                   Draw="Canvas_Draw"
                                   PointerPressed="Canvas_PointerPressed"
                                   PointerMoved="Canvas_PointerMoved"
                                   PointerReleased="Canvas_PointerReleased"
                                   PointerCaptureLost="Canvas_PointerCaptureLost"
                                   DoubleTapped="Canvas_DoubleTapped"/>
        </Grid>

        <TextBlock Text="Drag to add or shape a point · double-click to remove"
                   FontSize="{StaticResource AppFontSizeXxs}"
                   Foreground="{StaticResource AppTextMutedBrush}"/>
    </StackPanel>
</UserControl>
