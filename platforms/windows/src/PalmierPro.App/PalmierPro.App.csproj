<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>PalmierPro.App</RootNamespace>
    <AssemblyName>PalmierPro.App</AssemblyName>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.*" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.*" />
    <PackageReference Include="Serilog" Version="4.*" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.*" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.*" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="9.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\PalmierPro.Core\PalmierPro.Core.csproj" />
    <ProjectReference Include="..\PalmierPro.Services\PalmierPro.Services.csproj" />
    <ProjectReference Include="..\PalmierPro.Rendering\PalmierPro.Rendering.csproj" />
  </ItemGroup>

  <!--
    Bundled caption/title fonts (mirrors Utilities/BundledFonts.swift), linked — not copied — from
    the Mac resources so there's one on-disk copy of each font. Variable-font files whose names
    contain '[' ']' (their wght/opsz axis tags) are renamed via Link to "-Variable.ttf": brackets
    are legal on disk but break ms-appx:/// URIs, which XAML/DirectWrite use to load them.
  -->
  <ItemGroup>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Anton\Anton-Regular.ttf">
      <Link>Assets\Fonts\Anton\Anton-Regular.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\BasementGrotesque\BasementGrotesque-Black.ttf">
      <Link>Assets\Fonts\BasementGrotesque\BasementGrotesque-Black.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\BebasNeue\BebasNeue-Regular.ttf">
      <Link>Assets\Fonts\BebasNeue\BebasNeue-Regular.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Caveat\Caveat[wght].ttf">
      <Link>Assets\Fonts\Caveat\Caveat-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\DMSans\DMSans[opsz,wght].ttf">
      <Link>Assets\Fonts\DMSans\DMSans-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Geist\Geist[wght].ttf">
      <Link>Assets\Fonts\Geist\Geist-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Geist\Geist-Italic[wght].ttf">
      <Link>Assets\Fonts\Geist\Geist-Italic-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\GeistMono\GeistMono[wght].ttf">
      <Link>Assets\Fonts\GeistMono\GeistMono-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\GeistMono\GeistMono-Italic[wght].ttf">
      <Link>Assets\Fonts\GeistMono\GeistMono-Italic-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Inter\Inter[opsz,wght].ttf">
      <Link>Assets\Fonts\Inter\Inter-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\PermanentMarker\PermanentMarker-Regular.ttf">
      <Link>Assets\Fonts\PermanentMarker\PermanentMarker-Regular.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\PlayfairDisplay\PlayfairDisplay[wght].ttf">
      <Link>Assets\Fonts\PlayfairDisplay\PlayfairDisplay-Variable.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Poppins\Poppins-Bold.ttf">
      <Link>Assets\Fonts\Poppins\Poppins-Bold.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Poppins\Poppins-BoldItalic.ttf">
      <Link>Assets\Fonts\Poppins\Poppins-BoldItalic.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Poppins\Poppins-Italic.ttf">
      <Link>Assets\Fonts\Poppins\Poppins-Italic.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Poppins\Poppins-Regular.ttf">
      <Link>Assets\Fonts\Poppins\Poppins-Regular.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\Shrikhand\Shrikhand-Regular.ttf">
      <Link>Assets\Fonts\Shrikhand\Shrikhand-Regular.ttf</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\..\..\Sources\PalmierPro\Resources\Fonts\SpaceGrotesk\SpaceGrotesk[wght].ttf">
