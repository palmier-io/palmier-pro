<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <RootNamespace>PalmierPro.Services.Tests</RootNamespace>
    <AssemblyName>PalmierPro.Services.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.*" />
    <PackageReference Include="xunit" Version="2.9.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.9.*" />
    <PackageReference Include="Shouldly" Version="4.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\PalmierPro.Core\PalmierPro.Core.csproj" />
    <ProjectReference Include="..\..\src\PalmierPro.Services\PalmierPro.Services.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Checked-in golden snapshot JSON (docs/timeline-snapshot-v1.md §10) — the native agent
         parses copies of these once the timeline ABI lands; TimelineSnapshotBuilderTests asserts
         the builder's live output still matches them byte-for-byte (modulo {{FIXTURE_DIR}}). -->
    <Content Include="Engine\Fixtures\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
